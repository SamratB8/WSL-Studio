<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="CompactCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>

    <Style x:Key="ListItemCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CompactCardBorderStyle}">
        <Setter Property="Margin" Value="{StaticResource ListItemMargin}" />
    </Style>

    <Style x:Key="BadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource BadgeCornerRadius}" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
</ResourceDictionary>
