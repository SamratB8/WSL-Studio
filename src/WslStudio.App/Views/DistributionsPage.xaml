<Page
    x:Class="WslStudio.App.Views.DistributionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WslStudio.App.Controls"
    Loaded="OnLoaded">
    <ScrollViewer>
        <Grid MaxWidth="1180" Padding="32" RowSpacing="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PageTitleTextBlockStyle}" Text="{Binding Title}" />
                <TextBlock Style="{StaticResource PageSubtitleTextBlockStyle}" Text="{Binding Subtitle}" />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                x:Name="LoadingState"
                x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                HorizontalAlignment="Center"
                Spacing="12">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Loading distributions..." />
            </StackPanel>

            <controls:InfoCard
                Grid.Row="1"
                x:Name="EmptyState"
                x:Load="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                Title="No distributions found"
                Description="WSL did not report any installed distributions. This page only shows real read-only data returned by WSL."
                Icon="Library" />

            <controls:InfoCard
                Grid.Row="1"
                x:Name="ErrorState"
                x:Load="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Title="Distribution discovery could not complete"
                Description="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Icon="Important" />

            <ListView
                Grid.Row="1"
                x:Name="DistributionsList"
                x:Load="{x:Bind ViewModel.HasDistributions, Mode=OneWay}"
                ItemsSource="{x:Bind ViewModel.Distributions, Mode=OneWay}"
                SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="16,0,16,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Name" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="State" />
                        <TextBlock Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="WSL version" />
                        <TextBlock Grid.Column="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Default" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:DistributionListItemViewModel" xmlns:viewModels="using:WslStudio.App.ViewModels">
                        <Border
                            Margin="0,4"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Name}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind State}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind Version}" />
                                <Border
                                    Grid.Column="3"
                                    Padding="10,4"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="6">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind DefaultStatus}" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </ScrollViewer>
</Page>
