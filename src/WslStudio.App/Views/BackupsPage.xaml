<Page
    x:Class="WslStudio.App.Views.BackupsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WslStudio.App.Controls">
    <ScrollViewer>
        <Grid MaxWidth="1180" Padding="32" RowSpacing="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PageTitleTextBlockStyle}" Text="{Binding Title}" />
                <TextBlock Style="{StaticResource PageSubtitleTextBlockStyle}" Text="{Binding Subtitle}" />
            </StackPanel>

            <controls:InfoCard
                Grid.Row="1"
                Title="Backup workflows are coming soon"
                Description="This area will support explicit export and recovery paths before destructive distribution actions are introduced."
                Icon="Save" />
        </Grid>
    </ScrollViewer>
</Page>
