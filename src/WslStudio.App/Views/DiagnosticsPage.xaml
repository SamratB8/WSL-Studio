<Page
    x:Class="WslStudio.App.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WslStudio.App.Controls"
    xmlns:viewModels="using:WslStudio.App.ViewModels"
    Loaded="OnLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="{StaticResource PageMaxWidth}"
            Padding="{StaticResource PagePadding}"
            RowSpacing="{StaticResource CardRowSpacing}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PageTitleTextBlockStyle}" Text="{Binding Title}" />
                <TextBlock Style="{StaticResource PageSubtitleTextBlockStyle}" Text="{Binding Subtitle}" />
            </StackPanel>

            <controls:LoadingState
                Grid.Row="1"
                x:Name="LoadingState"
                x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Message="Running read-only health checks..." />

            <controls:EmptyState
                Grid.Row="1"
                x:Name="EmptyState"
                x:Load="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                Title="No health checks available"
                Description="Health Center did not return any checks."
                Icon="Find" />

            <controls:ErrorState
                Grid.Row="1"
                x:Name="ErrorState"
                x:Load="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Title="Health Center could not load"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

            <Grid
                Grid.Row="1"
                x:Name="HealthCenterState"
                x:Load="{x:Bind ViewModel.HasHealthChecks, Mode=OneWay}"
                RowSpacing="{StaticResource CardRowSpacing}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CompactCardBorderStyle}">
                    <Grid ColumnSpacing="{StaticResource SectionColumnSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <controls:SectionHeader
                            Title="{x:Bind ViewModel.OverallStatus, Mode=OneWay}"
                            Description="{x:Bind ViewModel.Recommendation, Mode=OneWay}" />
                        <controls:StatusBadge
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Text="Read-only" />
                    </Grid>
                </Border>

                <ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind ViewModel.SummaryCards, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MaximumRowsOrColumns="4"
                            MinItemWidth="160"
                            MinRowSpacing="{StaticResource CardRowSpacing}"
                            MinColumnSpacing="{StaticResource CardColumnSpacing}" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OverviewCardViewModel">
                            <controls:StatCard
                                Title="{x:Bind Title}"
                                Value="{x:Bind Value}"
                                Description="{x:Bind Description}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <ItemsRepeater Grid.Row="2" ItemsSource="{x:Bind ViewModel.HealthCheckGroups, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:HealthCheckGroupViewModel">
                            <StackPanel Margin="0,0,0,12" Spacing="8">
                                <controls:SectionHeader Title="{x:Bind Category}" />
                                <ItemsRepeater ItemsSource="{x:Bind Checks}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:HealthCheckItemViewModel">
                                            <Border
                                                Margin="{StaticResource ListItemMargin}"
                                                Style="{StaticResource CompactCardBorderStyle}">
                                                <Grid ColumnSpacing="{StaticResource CardColumnSpacing}" RowSpacing="6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock
                                                        Style="{StaticResource ListPrimaryTextBlockStyle}"
                                                        Text="{x:Bind Name}" />
                                                    <controls:StatusBadge
                                                        Grid.Column="1"
                                                        Text="{x:Bind Status}" />
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Style="{StaticResource BodySecondaryTextBlockStyle}"
                                                        Text="{x:Bind Summary}" />
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.ColumnSpan="2"
                                                        Style="{StaticResource BodySecondaryTextBlockStyle}"
                                                        Text="{x:Bind Recommendation}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
