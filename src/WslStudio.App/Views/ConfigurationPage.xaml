<Page
    x:Class="WslStudio.App.Views.ConfigurationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WslStudio.App.Controls">
    <ScrollViewer>
        <Grid MaxWidth="1180" Padding="32" RowSpacing="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PageTitleTextBlockStyle}" Text="{Binding Title}" />
                <TextBlock Style="{StaticResource PageSubtitleTextBlockStyle}" Text="{Binding Subtitle}" />
            </StackPanel>

            <controls:InfoCard
                Grid.Row="1"
                Title="Configuration tools are planned"
                Description="Future configuration screens will focus on supported settings, validation, and clear review before applying changes."
                Icon="Setting" />
        </Grid>
    </ScrollViewer>
</Page>
