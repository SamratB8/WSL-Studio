<Page
    x:Class="WslStudio.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WslStudio.App.Controls"
    xmlns:viewModels="using:WslStudio.App.ViewModels"
    Loaded="OnLoaded">
    <ScrollViewer>
        <Grid
            MaxWidth="{StaticResource PageMaxWidth}"
            Padding="{StaticResource PagePadding}"
            HorizontalAlignment="Stretch"
            RowSpacing="{StaticResource PageRowSpacing}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <controls:SectionHeader Grid.Row="0" Description="{Binding Subtitle}" />

            <controls:LoadingState
                Grid.Row="1"
                x:Name="LoadingState"
                x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Message="Loading WSL overview..." />

            <controls:EmptyState
                Grid.Row="1"
                x:Name="EmptyState"
                x:Load="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                Title="No distributions found"
                Description="WSL did not report any installed distributions. This dashboard only shows real read-only data returned by WSL."
                Icon="Library" />

            <controls:ErrorState
                Grid.Row="1"
                x:Name="ErrorState"
                x:Load="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Title="Dashboard overview could not load"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

            <Grid
                Grid.Row="1"
                x:Name="OverviewState"
                x:Load="{x:Bind ViewModel.HasOverview, Mode=OneWay}"
                RowSpacing="{StaticResource CardRowSpacing}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.OverviewCards, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MaximumRowsOrColumns="4"
                            MinItemWidth="220"
                            MinRowSpacing="{StaticResource CardRowSpacing}"
                            MinColumnSpacing="{StaticResource CardColumnSpacing}" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OverviewCardViewModel">
                            <controls:StatCard
                                Title="{x:Bind Title}"
                                Value="{x:Bind Value}"
                                Description="{x:Bind Description}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnSpacing="{StaticResource SectionColumnSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="48"
                            Height="48"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="8">
                            <SymbolIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Symbol="Find" />
                        </Border>

                        <Grid Grid.Column="1" ColumnSpacing="24" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <controls:SectionHeader Title="WSL environment" />
                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource BodySecondaryTextBlockStyle}"
                                Text="{x:Bind ViewModel.WslStatus, Mode=OneWay}"
                                TextWrapping="Wrap" />

                            <controls:SectionHeader
                                Grid.Column="1"
                                Title="WSL version" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource BodySecondaryTextBlockStyle}"
                                Text="{x:Bind ViewModel.WslVersion, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="{StaticResource SectionColumnSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="48"
                        Height="48"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Symbol="Home" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <controls:SectionHeader
                            Title="Read-only preview"
                            Description="The dashboard uses official read-only WSL commands. Lifecycle actions and destructive operations are intentionally not available here." />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
