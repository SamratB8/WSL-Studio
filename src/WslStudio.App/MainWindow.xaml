<Window
    x:Class="WslStudio.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WSL Studio">
    <NavigationView
        x:Name="ShellNavigationView"
        CompactPaneLength="48"
        Header="Dashboard"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="True"
        Loaded="OnShellNavigationViewLoaded"
        OpenPaneLength="280"
        PaneDisplayMode="Left"
        SelectionChanged="OnShellNavigationViewSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Dashboard" Tag="Dashboard">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Distributions" Tag="Distributions">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Library" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Configuration" Tag="Configuration">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Backups" Tag="Backups">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Save" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Diagnostics" Tag="Diagnostics">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Find" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Environment" Tag="Environment">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Globe" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
